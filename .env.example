# Suzu-JS configuration. Copy to your data dir as `.env`
# (default: ~/.suzu-js/.env) or run `suzu config`.
#
# NEVER commit a real .env — it holds your bot token and API key.

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Optional: restrict who can use the bot (comma-separated numeric user ids).
# Leave empty to allow everyone.
TELEGRAM_ALLOWED_USER_IDS=
# Optional: admins who may approve/ban users, view chats, run /setapi, etc.
# (defaults to the allowed list). Get your id by typing /id to the bot.
TELEGRAM_ADMIN_USER_IDS=
# Require admin approval before new users can use the AI (0 = open, 1 = on).
# When on, new users start as "pending" and admins get Approve/Ban buttons.
SUZU_REQUIRE_APPROVAL=0

# --- AI API (universal / custom — change any time, even via /setapi) ---
AI_API_BASE_URL=https://api.cybersecdev.cloud/v1
AI_API_KEY=
AI_DEFAULT_MODEL=qwen3.6-plus

# --- Optional tuning ---
# SUZU_MAX_TOOL_ITERS=40
# SUZU_MAX_TOKENS=8192
# SUZU_CONTEXT_CHAR_BUDGET=48000
# SUZU_ENABLE_VISION=1
# SUZU_DEBUG=0

# --- Download server (HTTP) + delivery ---
# Built-in file server for per-user download links (no extra deps).
# SUZU_HTTP_ENABLE=1
# SUZU_HTTP_PORT=8088
# Public base URL if reachable from outside (e.g. https://re.example.com).
# Leave empty to use the server's LAN IP / localhost in links.
# SUZU_PUBLIC_URL=
# Optional host/IP hint used to build links when SUZU_PUBLIC_URL is empty.
# SUZU_PUBLIC_HOST=
# Files <= this many MB are sent straight into the Telegram chat; larger ones
# are offered as a download link + SFTP path instead.
# SUZU_TG_SEND_LIMIT_MB=20

# --- Signing (auto-created by install.sh) ---
# SUZU_KEYSTORE=~/.suzu-js/keystores/debug.keystore
# SUZU_KEYSTORE_PASS=android
# SUZU_KEYSTORE_ALIAS=androiddebugkey
